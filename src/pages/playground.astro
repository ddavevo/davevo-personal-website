<script defer>
    function myFunction(btn) {
        btn.classList.toggle("active");
        btn.closest(".header").classList.toggle("menu-open");
    }

    const img = document.querySelector("#this-website");
    const gnarly = document.querySelector("#this-website audio");

    img.addEventListener("mouseover", () => {
        gnarly.play();
    });
    img.addEventListener("mouseleave", () => {
        gnarly.pause();
        gnarly.currentTime = 0;
    });
</script>

