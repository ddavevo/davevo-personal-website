---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UCSD Design Lab - Dave Vo</title>
    <link rel="icon" type="image/x-icon" href="https://media.dave-vo.com/file/dvfolio/general/davevo_favicon.png">
    
    <!--CSS-->
    <link rel="preload" href="/fonts/gravity-regular.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/fonts/gravity-bold.woff2" as="font" type="font/woff2" crossorigin>

    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@1,500&display=swap">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@1,500&display=swap" media="print" onload="this.media='all'">
    <noscript>
        <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@1,500&display=swap">
    </noscript>
    
    <link rel="stylesheet" href="../styles/general.css">
    <link rel="stylesheet" href="../styles/boilerplate.css">
    <link rel="stylesheet" href="../styles/case-studies.css">

    <script src="../javascript/case-study-links.js"></script>
</head>

<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-D3KQT24T12"></script>
<script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-D3KQT24T12');
</script>

<BaseLayout>
    <section class="locked">
        <h2>Confidential check 🔒</h2>
        <p>If you would like to request an access code, please reach me at dtvo@ucsd.edu. Thanks!</p>
        
        <form class="locked-input">
            <input type="password" id="typedPassword"><br>
            <button id="nda-button" onclick="checkPassword(event)"><b style="-webkit-text-stroke: var(--bg); font-size: 1.05rem;">Unlock</b></button>
        </form>

        <script>
            const typedPassword = document.getElementById('typedPassword');
            function checkPassword(event) {
                event.preventDefault();
                if (typedPassword.value === "brain") {
                    window.location.href = '../case-studies/designlab.html';
                } else {
                    alert("Incorrect password."); 
                }
            }
        </script>
        
        <a href="../index.html"><p class="subtitle">↩ Return to Home</p></a>
    </section>
</BaseLayout>
</html>