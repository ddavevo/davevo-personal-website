---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title} - Dave Vo</title>
    <link rel="icon" type="image/x-icon" href="https://media.dave-vo.com/file/dvfolio/general/davevo_favicon.png">

    <link href="/fonts/gravity-regular.woff2" as="font" type="font/woff2" crossorigin>
    <link href="/fonts/gravity-bold.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,WONK@1,9..144,1&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" crossorigin>
    <noscript>
        <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,WONK@1,9..144,1&display=swap">
    </noscript>

    <!-- ======================================= -->

    <link rel="preload" href="/styles/general.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="/styles/general.css"></noscript>

    <link rel="preload" href="/styles/boilerplate.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="/styles/boilerplate.css"></noscript>

    <script defer>
        function myFunction(btn) {
            btn.classList.toggle("active");
            btn.closest(".header").classList.toggle("menu-open");
        }
    </script>

    <script src="/javascript/case-study-links.js" defer></script>

    <slot name="head" />
  </head>

  <body>
    <Header />
    <slot />
    <Footer />
  </body>
</html>