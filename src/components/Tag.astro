---
const { surfaceColor, borderColor, textColor, text, margin, class: className, ...rest } = Astro.props;
---

<style>
    .tag {
        display: inline-block;
        width: fit-content;
        border-radius: 100px;
        padding: .25rem 0.75rem;
        vertical-align: var(--Scale-100);
    }
</style>

<span style={`background-color: ${surfaceColor ?? 'var(--surface-page)'}; 
              border: var(--border-thin) solid ${borderColor ?? 'var(--border-tag)'};
              color: ${textColor ?? 'var(--text-body-on-light)'};
              margin: ${margin ?? '0 0 0.75rem 0'};`}
      class:list={["tag", className]} {...rest}>
    {text}
</span>