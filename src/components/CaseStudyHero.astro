---
const { heroMediaUrl, caseStudyTitle, logisticItems, ribbonOffset, ribbonImageUrl } = Astro.props;
---

<style>
    #case-study-title { /* 910px - 3 lines | 657px - 4 lines | 512px - 5 lines | 442px - 6 lines*/
        margin: 0 auto;
        padding: 2.4rem;
        max-width: var(--width-max);
        font-size-adjust: from-font;
        color: var(--text-heading-on-dark);
        text-align: center;
    }

    .hero {
        width: 100%;
        background-image: linear-gradient(to bottom, var(--teal-700), var(--teal-900));
        color: var(--text-heading-on-dark);
        padding-top: 6rem;
        min-height: calc(6rem + 300px + 7.5rem + (1.2em * 6) + 4.8rem); 
    }

    .hero:after {
        content: "";
        display: block;
        clear: both;
    }

    .hero .lottie-anim, .hero picture, .hero video {
        display: block;
        aspect-ratio: 16/9;
        object-fit: cover;
        margin: 0 auto;
        overflow: hidden;
    }

    .logistics {
        display: flex;
        justify-content: space-around; gap: 1rem 0;
        padding: 0 2.4rem 2.4rem;
        max-width: var(--width-max); margin: 0 auto;
        min-height: 8.75rem;
    }

    .hero .subtitle {
        margin-bottom: 0.5rem;
    }

    .hero p, .hero b {
        color: var(--text-body-bold-on-dark);
    }

    .hero-ribbon {
        position: relative;
        width: 100%;
        height: 0.8rem;
        background-image: var(--gradient-case-study);
    }

    .hero-ribbon img {
        position: absolute;
        width: 80px;
        height: 74px;
        right: 8%;
        transform: translateY(-50%);
    }

    @media screen and (max-width: 623px) {
        #case-study-title {
            text-align: left;
        }

        .logistics {
            display: grid;
            grid-template-columns: 1fr 1fr;
            min-height: 15rem;
        }
    }
</style>

<section class="hero">
    <video autoplay muted loop playsinline webkit-playsinline preload="none" width="100%">
        <source data-src={`${heroMediaUrl}.mp4`} type="video/mp4"/>
        <source data-src={`${heroMediaUrl}.webm`} type="video/webm"/>
    </video>
    
    <h1 id="case-study-title" class="fraunces">{caseStudyTitle}</h1>
    <div class="logistics">
        <div>
            <p class="subtitle">My Role</p>
            <p set:html={logisticItems[0].join('<br>')} />
        </div>
        <div>
            <p class="subtitle">Team</p>
            <p set:html={logisticItems[1].join('<br>')} />
        </div>

        <div>
            <p class="subtitle">Skills</p>
            <p set:html={logisticItems[2].join('<br>')} />
            
        </div>
        <div>
            <p class="subtitle">Timeline</p>
            <p set:html={logisticItems[3].join('<br>')} />
        </div>
    </div>
</section>
<div class="hero-ribbon">
    <img style=`transform: ${ribbonOffset};` src=`${ribbonImageUrl}.png` alt="Decorative ribbon image"/>
</div>